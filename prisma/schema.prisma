generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Peran {
  MAHASISWA
  DOSEN
  STAF
}

enum Status {
  AKTIF
  NONAKTIF
}

enum StatusKartu {
  AKTIF
  HILANG
  DIBLOKIR
}

enum TipeGate {
  MASUK
  KELUAR
}

enum Sumber {
  HARDWARE
  DEMO
}

enum StatusLog {
  MASUK
  KELUAR
  ANOMALI
}

model Pengguna {
  id         String      @id @default(uuid())
  nama       String
  nimNip     String      @unique
  peran      Peran
  status     Status      @default(AKTIF)
  dibuatPada DateTime    @default(now())
  kartuRfid  KartuRfid[]
}

model KartuRfid {
  id          String      @id @default(uuid())
  penggunaId  String
  pengguna    Pengguna    @relation(fields: [penggunaId], references: [id])
  uidKartu    String      @unique
  status      StatusKartu @default(AKTIF)
  aktifDari   DateTime    @default(now())
  aktifHingga DateTime?
  logParkir   LogParkir[]

  @@index([uidKartu])
}

model Gate {
  id        String      @id @default(uuid())
  nama      String
  tipe      TipeGate
  lokasi    String
  status    Status      @default(AKTIF)
  logMasuk  LogParkir[] @relation("GateMasuk")
  logKeluar LogParkir[] @relation("GateKeluar")
}

model LogParkir {
  id              String      @id @default(uuid())
  kartuRfidId     String?
  kartuRfid       KartuRfid?  @relation(fields: [kartuRfidId], references: [id])
  gateMasukId     String?
  gateMasuk       Gate?       @relation("GateMasuk", fields: [gateMasukId], references: [id])
  gateKeluarId    String?
  gateKeluar      Gate?       @relation("GateKeluar", fields: [gateKeluarId], references: [id])
  fotoMasuk       String?
  fotoKeluar      String?
  platNomorMasuk  String?
  platNomorKeluar String?
  sumber          Sumber      @default(DEMO)
  status          StatusLog
  waktuMasuk      DateTime    @default(now())
  waktuKeluar     DateTime?

  @@index([kartuRfidId, status])
}

model Account {
  id                 String  @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
